PORT=5000

# ── AI Suggestions — Groq API (FREE, no credit card, works from India) ─────────
#
# STEP 1: Go to https://console.groq.com and sign up (Google/GitHub login works)
# STEP 2: Click "API Keys" in the left sidebar → "Create API Key"
# STEP 3: Name it anything → click "Submit"
# STEP 4: Copy the key — it starts with "gsk_"
# STEP 5: Paste it below
# STEP 6: Restart the backend: Ctrl+C → npm run dev
#
# Free tier: 30 requests/minute, 14,400/day — more than enough for personal use.
# Model: llama-3.1-8b-instant — fast and high quality.
#
GROQ_API_KEY=gsk_your_key_here

# ── Live Jobs — Adzuna API (India jobs, free signup) ──────────────────────────
# Without these, falls back to Arbeitnow (free, remote/global jobs, no key needed)
# Sign up at: developer.adzuna.com
ADZUNA_APP_ID=your_id_here
ADZUNA_APP_KEY=your_key_here

# ── Optional: MongoDB (for future auth/history features) ──────────────────────
# Not needed for the current version — all features work without it.
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pratibhapath
# JWT_SECRET=replace-with-a-long-random-string
